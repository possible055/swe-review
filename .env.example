# Optional. Used by `swe-review --path ...` when `--api-key` is omitted.
# You can also save this value to `swe-tools/config.json` with:
# `swe-review extract-key --save`
WINDSURF_API_KEY=

# Optional Quick Review limits. Leave unset to use defaults.
# SWE_REVIEW_MAX_FILE_BYTES=1000000
# SWE_REVIEW_MAX_TOTAL_DIFF_BYTES=512000
# SWE_REVIEW_MAX_TOTAL_DIFF_LINES=12000
# SWE_REVIEW_MAX_ESTIMATED_TOKENS=120000
# SWE_REVIEW_TIMEOUT_MS=120000
